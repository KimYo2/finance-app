# UWANGKU Environment Variables
# Copy this file to .env and fill in your actual values

# Groq API Key (for AI chat and receipt scanning)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Gemini API Key (optional, for additional AI features)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Midtrans Configuration (for payment processing)
# NOTE: Server key should NOT be in Flutter app - use PocketBase hook instead
MIDTRANS_SERVER_KEY=your_midtrans_server_key_here
MIDTRANS_BASE_URL=https://app.sandbox.midtrans.com/snap/v1/transactions